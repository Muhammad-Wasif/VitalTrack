<Window x:Class="VitalTrack.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VitalTrack — Login"
        Width="920" Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="20" ClipToBounds="True">
        <Grid>
            <!-- Left: Branding panel -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0" Background="{StaticResource AccentGradientBrush}">
                <Grid>
                    <!-- Background decoration -->
                    <Ellipse Width="300" Height="300" Margin="-100,-100,0,0"
                             Fill="#22FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Ellipse Width="200" Height="200" Margin="0,0,-60,-60"
                             Fill="#22FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <!-- Logo -->
                        <TextBlock Text="⚡" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="VitalTrack" FontFamily="Segoe UI Black" FontSize="36"
                                   Foreground="White" HorizontalAlignment="Center" FontWeight="Black"/>
                        <TextBlock Text="Universal Health &amp; Fitness Tracker"
                                   Foreground="#CCffffff" FontSize="14" HorizontalAlignment="Center"
                                   Margin="0,8,0,40" TextWrapping="Wrap" TextAlignment="Center"/>

                        <!-- Features list -->
                        <StackPanel Margin="0,0,0,0" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Gender-aware BMI / BMR / TDEE" Foreground="#DDffffff" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Nutrition &amp; Workout logging" Foreground="#DDffffff" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="AI-powered FitBot chatbot" Foreground="#DDffffff" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Role-based access control" Foreground="#DDffffff" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT PANEL: Form -->
            <Border Grid.Column="1" Background="{StaticResource BgPrimaryBrush}">
                <Grid Margin="48,40">
                    <!-- Window drag + close -->
                    <Border Height="36" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                            Background="Transparent" Panel.ZIndex="10" MouseLeftButtonDown="TitleBar_MouseDown"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Panel.ZIndex="10"
                            Width="32" Height="32" Click="CloseButton_Click"
                            Style="{StaticResource GhostButtonStyle}" Padding="0"
                            Foreground="{StaticResource TextMutedBrush}"/>

                    <ScrollViewer Margin="0,36,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,16,20">

                        <!-- Tab switcher -->
                        <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="12"
                                Padding="4" Margin="0,0,0,28">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="LoginTabHighlight" Grid.Column="0"
                                        Background="{StaticResource AccentGradientBrush}"
                                        CornerRadius="9"/>
                                <Button x:Name="LoginTabBtn" Grid.Column="0" Content="Login"
                                        Click="ShowLogin_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        BorderThickness="0" Foreground="White" FontWeight="SemiBold"
                                        Background="Transparent" Padding="0,10"/>
                                <Button x:Name="SignupTabBtn" Grid.Column="1" Content="Sign Up"
                                        Click="ShowSignup_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        BorderThickness="0" Background="Transparent" Padding="0,10"/>
                            </Grid>
                        </Border>

                        <!-- ── LOGIN FORM ── -->
                        <StackPanel x:Name="LoginPanel" Visibility="Visible">
                            <TextBlock Text="Welcome back" FontFamily="Segoe UI Black"
                                       FontSize="22" Margin="0,0,0,4"/>
                            <TextBlock Text="Sign in to your account" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="13" Margin="0,0,0,24"/>

                            <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                        Margin="0,0,0,6"/>
                            <TextBox x:Name="LoginUsernameBox" Style="{StaticResource InputFieldStyle}"
                                     Margin="0,0,0,16" KeyDown="Login_KeyDown"/>

                            <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                        Margin="0,0,0,6"/>
                            <PasswordBox x:Name="LoginPasswordBox" Style="{StaticResource PasswordFieldStyle}"
                                         Margin="0,0,0,8" KeyDown="Login_KeyDown"/>

                            <TextBlock x:Name="LoginErrorText" Foreground="#FF6B8A" FontSize="12"
                                       Margin="0,0,0,16" Visibility="Collapsed" TextWrapping="Wrap"/>

                            <Button Content="Sign In" Style="{StaticResource PrimaryButtonStyle}"
                                    Height="46" FontSize="14" Click="Login_Click" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- ── SIGNUP FORM ── -->
                        <StackPanel x:Name="SignupPanel" Visibility="Collapsed">
                            <TextBlock Text="Create Account" FontFamily="Segoe UI Black"
                                       FontSize="22" Margin="0,0,0,4"/>
                            <TextBlock Text="Fill in your details below" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="13" Margin="0,0,0,20"/>

                            <!-- Username + Full Name row -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"  Margin="0,0,0,6"/>
                                    <TextBox x:Name="SuUsernameBox" Style="{StaticResource InputFieldStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="FULL NAME" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"  Margin="0,0,0,6"/>
                                    <TextBox x:Name="SuFullNameBox" Style="{StaticResource InputFieldStyle}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Email -->
                            <TextBlock Text="EMAIL" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"  Margin="0,0,0,6"/>
                            <TextBox x:Name="SuEmailBox" Style="{StaticResource InputFieldStyle}" Margin="0,0,0,14"/>

                            <!-- Gender + Age row -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="GENDER" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"  Margin="0,0,0,6"/>
                                    <ComboBox x:Name="SuGenderBox" Style="{StaticResource ComboFieldStyle}">
                                        <ComboBoxItem Content="Male"   IsSelected="True"/>
                                        <ComboBoxItem Content="Female"/>
                                        <ComboBoxItem Content="Other"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="AGE" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"  Margin="0,0,0,6"/>
                                    <TextBox x:Name="SuAgeBox" Style="{StaticResource InputFieldStyle}" Text="25"/>
                                </StackPanel>
                            </Grid>

                            <!-- Role -->
                            <TextBlock Text="ROLE" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"  Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="RoleUserBorder" Grid.Column="0"
                                        Background="#1AE040A2" BorderBrush="#33E040A2"
                                        BorderThickness="1" CornerRadius="10" Padding="0,10"
                                        Cursor="Hand" MouseLeftButtonDown="SelectRoleUser">
                                    <TextBlock Text="👤 Standard User" HorizontalAlignment="Center"
                                               Foreground="{StaticResource AccentPinkBrush}" FontWeight="SemiBold" FontSize="12"/>
                                </Border>
                                <Border x:Name="RoleAdminBorder" Grid.Column="2"
                                        Background="{StaticResource BgTertiaryBrush}" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="10" Padding="0,10"
                                        Cursor="Hand" MouseLeftButtonDown="SelectRoleAdmin">
                                    <TextBlock Text="🛡️ Admin" HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                </Border>
                            </Grid>

                            <!-- Admin code (hidden until Admin selected) -->
                            <StackPanel x:Name="AdminCodePanel" Visibility="Collapsed" Margin="0,0,0,14">
                                <TextBlock Text="ADMIN SECRET CODE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"  Margin="0,0,0,6"/>
                                <PasswordBox x:Name="SuAdminCodeBox" Style="{StaticResource PasswordFieldStyle}"/>
                            </StackPanel>

                            <!-- Password -->
                            <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"  Margin="0,0,0,6"/>
                            <PasswordBox x:Name="SuPasswordBox" Style="{StaticResource PasswordFieldStyle}" Margin="0,0,0,8"/>

                            <TextBlock x:Name="SignupErrorText" Foreground="#FF6B8A" FontSize="12"
                                       Margin="0,0,0,12" Visibility="Collapsed" TextWrapping="Wrap"/>

                            <Button Content="Create Account" Style="{StaticResource PrimaryButtonStyle}"
                                    Height="46" FontSize="14" Click="Signup_Click"/>
                        </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
