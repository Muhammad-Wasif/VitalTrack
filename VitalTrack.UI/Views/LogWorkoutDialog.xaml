<Window x:Class="VitalTrack.UI.Views.LogWorkoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Workout Session"
        Width="480" Height="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">

    <Border CornerRadius="16" Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Log Workout Session" FontFamily="Segoe UI Black" FontSize="18"/>
                <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                        Width="30" Height="30" Padding="0" Click="Cancel_Click"/>
            </Grid>

            <!-- Form -->
            <StackPanel Grid.Row="1">
                <!-- Exercise name -->
                <TextBlock Text="EXERCISE NAME" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" CharacterSpacing="120" Margin="0,0,0,6"/>
                <TextBox x:Name="ExerciseBox" Style="{StaticResource InputFieldStyle}" Margin="0,0,0,14"/>

                <!-- Muscle group -->
                <TextBlock Text="MUSCLE GROUP" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" CharacterSpacing="120" Margin="0,0,0,6"/>
                <ComboBox x:Name="MuscleBox" Style="{StaticResource ComboFieldStyle}" Margin="0,0,0,14">
                    <ComboBoxItem Content="Chest"/>
                    <ComboBoxItem Content="Back"/>
                    <ComboBoxItem Content="Legs"/>
                    <ComboBoxItem Content="Shoulders"/>
                    <ComboBoxItem Content="Biceps"/>
                    <ComboBoxItem Content="Triceps"/>
                    <ComboBoxItem Content="Core"/>
                    <ComboBoxItem Content="Glutes"/>
                    <ComboBoxItem Content="Cardio"/>
                    <ComboBoxItem Content="Full Body"/>
                </ComboBox>

                <!-- Sets / Reps / Weight row -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SETS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" CharacterSpacing="120" Margin="0,0,0,6"/>
                        <TextBox x:Name="SetsBox" Style="{StaticResource InputFieldStyle}" Text="3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="REPS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" CharacterSpacing="120" Margin="0,0,0,6"/>
                        <TextBox x:Name="RepsBox" Style="{StaticResource InputFieldStyle}" Text="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="WEIGHT (KG)" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" CharacterSpacing="120" Margin="0,0,0,6"/>
                        <TextBox x:Name="WeightBox" Style="{StaticResource InputFieldStyle}" Text="0"/>
                    </StackPanel>
                </Grid>

                <!-- Duration -->
                <TextBlock Text="DURATION (MINUTES)" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" CharacterSpacing="120" Margin="0,0,0,6"/>
                <TextBox x:Name="DurationBox" Style="{StaticResource InputFieldStyle}"
                         Text="30" Margin="0,0,0,14"/>

                <!-- Notes -->
                <TextBlock Text="NOTES (OPTIONAL)" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" CharacterSpacing="120" Margin="0,0,0,6"/>
                <TextBox x:Name="NotesBox" Style="{StaticResource InputFieldStyle}"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorText" Text="" Foreground="#FF6B8A" FontSize="12"
                           Visibility="Collapsed" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" Style="{StaticResource GhostButtonStyle}"
                        Height="44" Click="Cancel_Click"/>
                <Button Grid.Column="2" Content="Log Session" Style="{StaticResource PrimaryButtonStyle}"
                        Height="44" Click="Save_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
