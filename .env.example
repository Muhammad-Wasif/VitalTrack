# ═══════════════════════════════════════════════════════════
# VitalTrack — Environment Variables
# Copy this file to .env and fill in your actual keys.
# The .env file is loaded automatically on app startup via dotenv.net.
# NEVER commit the real .env file to source control.
# ═══════════════════════════════════════════════════════════

# ── Microsoft SQL Server Connection String ──────────────────
# Local (Windows Auth):
DB_CONNECTION_STRING=Server=localhost;Database=VitalTrackDb;Trusted_Connection=True;TrustServerCertificate=True;

# SQL Server with username/password:
# DB_CONNECTION_STRING=Server=localhost;Database=VitalTrackDb;User Id=sa;Password=YourPassword;TrustServerCertificate=True;

# Azure SQL:
# DB_CONNECTION_STRING=Server=tcp:yourserver.database.windows.net,1433;Database=VitalTrackDb;User Id=your_user;Password=your_pass;Encrypt=True;

# ── Hugging Face API (AI Chatbot) ───────────────────────────
# Get your free key at: https://huggingface.co/settings/tokens
# Model used: mistralai/Mistral-7B-Instruct-v0.1 (free tier)
HUGGINGFACE_API_KEY=hf_YOUR_KEY_HERE

# ── ExerciseDB (RapidAPI) ───────────────────────────────────
# Free tier: https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
# Provides gender-filtered exercise suggestions
EXERCISEDB_API_KEY=YOUR_RAPIDAPI_KEY_HERE

# ── Open Food Facts ─────────────────────────────────────────
# Completely FREE, no key required.
# Used for food search and nutritional data.
# Doc: https://world.openfoodfacts.org/data

# ── Admin Registration Secret Code ──────────────────────────
# Change this to your own secret before deploying.
# Users must enter this code to register as Admin.
ADMIN_SECRET_CODE=VITALTRACK_ADMIN_2025
